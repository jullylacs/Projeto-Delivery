# ─────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=delivery_sys
DB_USER=postgres
DB_PASS=sua_senha_aqui
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# ─────────────────────────────────────────────────
# JWT — OBRIGATÓRIO! Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────
JWT_SECRET=troque_por_uma_chave_segura_64_caracteres

# ─────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────
PORT=3000
HOST=localhost
NODE_ENV=development
REQUEST_BODY_LIMIT=5mb
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=5000

# ─────────────────────────────────────────────────
# CORS - Front-end URL (para development)
# ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
