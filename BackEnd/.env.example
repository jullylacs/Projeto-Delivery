# ─────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=delivery_sys
DB_USER=postgres
DB_PASS=sua_senha_aqui

# ─────────────────────────────────────────────────
# JWT — troque por uma chave longa e aleatória em produção
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────
JWT_SECRET=troque_por_uma_chave_segura

# ─────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
