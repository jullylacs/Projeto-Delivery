# ────────── PostgreSQL ──────────
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=delivery_sys
DB_USER=postgres
DB_PASS=sua_senha_aqui
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
# ────────── Server ──────────
HOST=localhost
PORT=3000
NODE_ENV=development
# ────────── API ──────────
API_BASE_PATH=/api/v1
ENABLE_LEGACY_ROUTES=false
REQUEST_BODY_LIMIT=5mb
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=5000
# ────────── Security ──────────
# Gere chaves com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_uma_chave_segura_64_caracteres
JWT_REFRESH_SECRET=troque_por_uma_chave_segura_64_caracteres
SYSTEM_API_TOKEN=troque_por_uma_chave_segura_64_caracteres
# ────────── Network ──────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://delivery.nvxnetworks.com,http://10.0.254.32:5173
